<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>늘품마트 - "너의 가능성을 믿어"</title>
    <style>
        :root {
            --bg-color: #f0f4f8;
            --store-bg: #ffffff;
            --checkout-bg: #e3f2fd;
            --wallet-bg: #fff9db;
            --primary-color: #4a90e2;
            --accent-color: #ff6b6b;
            --success-color: #4caf50;
            --admin-color: #673ab7;
            --help-color: #ff922b;
        }

        body {
            font-family: 'Pretendard', -apple-system, BlinkMacSystemFont, system-ui, Roboto, sans-serif;
            background-color: var(--bg-color);
            margin: 0;
            padding: 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
            user-select: none;
        }

        header {
            width: 100%;
            max-width: 1200px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            background: white;
            padding: 15px 25px;
            border-radius: 20px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
        }

        .level-selector button, .help-btn, .admin-btn {
            padding: 12px 20px;
            font-size: 1rem;
            font-weight: bold;
            border: none;
            border-radius: 12px;
            cursor: pointer;
            transition: all 0.2s;
            margin-right: 5px;
        }

        .level-btn.active { background-color: var(--primary-color); color: white; }
        .level-btn { background-color: #eee; }
        .help-btn { background-color: var(--help-color); color: white; }
        .admin-btn { background-color: var(--admin-color); color: white; }

        main {
            display: grid;
            grid-template-columns: 1fr 1.2fr 1fr;
            gap: 20px;
            width: 100%;
            max-width: 1200px;
            height: 700px;
        }

        .panel {
            background: white;
            border-radius: 25px;
            padding: 20px;
            box-shadow: 0 8px 15px rgba(0,0,0,0.1);
            display: flex;
            flex-direction: column;
        }

        .panel-header {
            display: flex;
            justify-content: center;
            align-items: center;
            position: relative;
            margin-bottom: 15px;
        }

        .clear-cart-btn {
            position: absolute;
            right: 0;
            padding: 5px 10px;
            font-size: 0.8rem;
            background: #eee;
            border: none;
            border-radius: 8px;
            cursor: pointer;
        }

        h2 { text-align: center; color: #444; margin: 0; font-size: 1.5rem; }

        .store-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
            overflow-y: auto;
        }

        .item-card {
            background: #f8f9fa;
            border: 3px solid transparent;
            border-radius: 15px;
            padding: 15px;
            text-align: center;
            cursor: pointer;
            transition: all 0.2s;
            position: relative;
        }

        .item-card:hover { border-color: var(--primary-color); background: #e7f5ff; }
        
        .item-img {
            width: 80px;
            height: 80px;
            object-fit: contain;
            margin-bottom: 10px;
            border-radius: 10px;
        }
        
        .item-emoji { font-size: 3rem; display: block; margin-bottom: 10px; }
        .item-price { font-weight: bold; color: var(--accent-color); font-size: 1.2rem; }

        .checkout-panel { background-color: var(--checkout-bg); }
        .cart-list {
            flex-grow: 1;
            background: white;
            border-radius: 15px;
            padding: 10px;
            margin-bottom: 15px;
            overflow-y: auto;
            border: 2px dashed #adc6ff;
        }
        
        .cart-item { 
            display: flex; 
            justify-content: space-between; 
            align-items: center;
            padding: 10px; 
            border-bottom: 1px solid #eee; 
        }
        
        .remove-btn {
            background: #ff4d4f;
            color: white;
            border: none;
            width: 24px;
            height: 24px;
            border-radius: 50%;
            cursor: pointer;
            font-weight: bold;
            font-size: 0.8rem;
        }

        .total-display { font-size: 1.8rem; font-weight: 800; text-align: right; margin-bottom: 15px; color: #1e3a8a; }

        .drop-zone {
            height: 200px;
            background: rgba(255,255,255,0.8);
            border: 4px dashed var(--primary-color);
            border-radius: 20px;
            display: flex;
            flex-wrap: wrap;
            align-content: flex-start;
            padding: 10px;
            position: relative;
            overflow: hidden;
        }
        .drop-zone.dragover { background: #d0ebff; }
        .drop-zone::after {
            content: '여기에 돈을 놓으세요';
            position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
            color: var(--primary-color); font-weight: bold; opacity: 0.5; pointer-events: none;
        }

        .paid-display {
            background: #fff; padding: 10px; border-radius: 10px; margin-top: 10px;
            font-size: 1.3rem; text-align: center; border: 2px solid var(--primary-color);
        }

        .wallet-panel { background-color: var(--wallet-bg); }
        .money-source { display: grid; grid-template-columns: 1fr 1fr; gap: 5px; align-items: center; padding-top: 10px; }

        .money-item {
            width: 100%; height: 75px; 
            background-color: transparent;
            display: flex; justify-content: center; align-items: center;
            cursor: grab; 
            background-size: contain;
            background-repeat: no-repeat;
            background-position: center;
            color: transparent;
            border: none;
            box-shadow: none;
        }
        
        .money-1000  { background-image: url('1000원.png'); }
        .money-5000  { background-image: url('5000원.png'); }
        .money-10000 { background-image: url('10000원.png'); }
        .money-50000 { background-image: url('50000원.png'); }
        .money-500   { background-image: url('500원.png'); height: 70px; }
        .money-100   { background-image: url('100원.png'); height: 60px; }

        .pay-btn {
            padding: 20px 60px; font-size: 1.5rem; background-color: #ccc;
            color: white; border: none; border-radius: 50px; cursor: not-allowed; transition: all 0.3s;
        }
        .pay-btn.enabled { background-color: var(--success-color); cursor: pointer; box-shadow: 0 6px 15px rgba(76, 175, 80, 0.4); }

        .modal {
            display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.7); justify-content: center; align-items: center; z-index: 1000;
        }
        
        .modal-content {
            background: white; padding: 30px; border-radius: 20px; width: 500px;
            max-height: 80vh; overflow-y: auto;
        }

        .help-modal-content {
            background: white; padding: 30px; border-radius: 20px; width: 700px;
            max-height: 85vh; overflow-y: auto;
        }
        .help-section { margin-bottom: 25px; border-bottom: 1px solid #eee; padding-bottom: 15px; }
        .help-section h4 { color: var(--primary-color); margin-bottom: 10px; display: flex; align-items: center; gap: 8px; }
        .help-step { display: flex; align-items: center; gap: 15px; margin-bottom: 10px; white-space: nowrap; }
        .step-num { background: var(--primary-color); color: white; border-radius: 50%; width: 24px; height: 24px; display: flex; justify-content: center; align-items: center; font-size: 0.8rem; flex-shrink: 0; }

        .admin-form { display: flex; flex-direction: column; gap: 10px; margin-bottom: 20px; padding: 15px; background: #f8f0ff; border-radius: 15px; }
        .admin-form input, .admin-form select { padding: 10px; border: 1px solid #ddd; border-radius: 8px; }
        .admin-item-row { display: flex; align-items: center; justify-content: space-between; padding: 10px; border-bottom: 1px solid #f0f0f0; }
        .delete-btn { background: #ff4d4f; color: white; border: none; padding: 5px 10px; border-radius: 5px; cursor: pointer; }
    </style>
</head>
<body onclick="initApp()">

    <header>
        <div class="level-selector">
            <button class="level-btn active" onclick="setLevel(1)">Level 1 (기초)</button>
            <button class="level-btn" onclick="setLevel(2)">Level 2 (심화)</button>
        </div>
        <div style="display: flex; flex-direction: column; align-items: center;">
            <div style="font-size: 1.8rem; font-weight: bold; color: var(--primary-color);">🛒 늘품마트</div>
            <div style="font-size: 0.9rem; color: #888; margin-top: 2px;">"너의 가능성을 믿어"</div>
        </div>
        <div>
            <button id="music-btn" class="help-btn" style="background-color: #5c7cfa;" onclick="toggleMusic()">🎵 배경음 ON</button>
            <button class="help-btn" onclick="openHelp()">❓ 도움말</button>
            <button class="admin-btn" onclick="openAdmin()">⚙️ 관리</button>
        </div>
    </header>

    <audio id="bg-music" loop>
        <source src="늘품마트 배경음악.mp3" type="audio/mpeg">
    </audio>

    <main>
        <section class="panel">
            <div class="panel-header"><h2>🍎 상점</h2></div>
            <div id="store-grid" class="store-grid"></div>
        </section>

        <section class="panel checkout-panel">
            <div class="panel-header">
                <h2>🧾 계산대</h2>
                <button class="clear-cart-btn" onclick="emptyCart()">전체 비우기</button>
            </div>
            <div id="cart-list" class="cart-list"></div>
            <div class="total-display">총액: <span id="total-amount">0</span>원</div>
            <div id="drop-zone" class="drop-zone"></div>
            <div class="paid-display">지불한 금액: <span id="paid-amount">0</span>원</div>
        </section>

        <section class="panel wallet-panel">
            <div class="panel-header"><h2>👛 지갑</h2></div>
            <div id="money-source" class="money-source"></div>
            <button style="margin-top: 15px; padding: 8px; cursor: pointer;" onclick="resetMoney()">💸 다시 지불</button>
        </section>
    </main>

    <div style="margin-top:20px;"><button id="pay-btn" class="pay-btn" onclick="completePayment()">결제하기</button></div>

    <footer style="position: fixed; bottom: 10px; left: 20px; font-size: 0.8rem; color: #aaa; text-align: left; pointer-events: none;">
        <div>Copyright 장근T</div>
        <div>문의: leejg4485@korea.kr</div>
    </footer>

    <div id="help-modal" class="modal">
        <div class="help-modal-content">
            <h2 style="margin-top:0; color:var(--help-color); text-align:center; border-bottom: 2px solid var(--help-color); padding-bottom: 10px;">❓ 늘품마트 이용 가이드</h2>
            <div class="help-section">
                <h4>🛒 학생용: 마트 이용 방법</h4>
                <div class="help-step"><span class="step-num">1</span> <span>상점에서 원하는 물건을 <strong>클릭</strong>하여 계산대에 담으세요.</span></div>
                <div class="help-step"><span class="step-num">2</span> <span>지갑에서 지폐나 동전을 <strong>클릭 후 드래그</strong>하여 계산대 상자 안에 놓으세요.</span></div>
                <div class="help-step"><span class="step-num">3</span> <span>지불한 금액이 총액보다 많아져 <strong>결제하기</strong> 버튼이 초록색이 되면 클릭하세요.</span></div>
                <div class="help-step"><span class="step-num">4</span> <span>영수증에서 <strong>거스름돈</strong>을 확인하고 '닫기'를 누르면 처음으로 돌아갑니다.</span></div>
            </div>
            <div class="help-section">
                <h4>⚙️ 교사용: 커스텀 상품 만들기</h4>
                <div class="help-step"><span class="step-num">1</span> <span>우측 상단의 <strong>[⚙️ 관리]</strong> 버튼을 클릭하여 관리자 창을 엽니다.</span></div>
                <div class="help-step"><span class="step-num">2</span> <span><strong>이름</strong>(예: 초코우유)과 <strong>가격</strong>(숫자만)을 입력하고 표시할 <strong>난이도(Level)</strong>를 정하세요.</span></div>
                <div class="help-step"><span class="step-num">3</span> <span><strong>[파일 선택]</strong> 버튼을 눌러 컴퓨터에 저장된 학생이 좋아하는 물건 사진을 올리세요.</span></div>
                <div class="help-step"><span class="step-num">4</span> <span><strong>[등록]</strong> 버튼을 누르면 즉시 상점에 나타납니다.</span></div>
            </div>
            <button onclick="closeHelp()" style="width:100%; padding:15px; background:var(--help-color); color:white; border:none; border-radius:12px; cursor:pointer; font-weight:bold;">알겠어요!</button>
        </div>
    </div>

    <div id="admin-modal" class="modal">
        <div class="modal-content">
            <h3 style="margin-top:0; color:var(--admin-color);">⚙️ 물건 관리</h3>
            <div class="admin-form">
                <input type="text" id="new-item-name" placeholder="물건 이름">
                <input type="number" id="new-item-price" placeholder="가격 (원)">
                <select id="new-item-level"><option value="1">Level 1</option><option value="2">Level 2</option></select>
                <input type="file" id="new-item-image" accept="image/*">
                <button onclick="addNewItem()" style="background:var(--admin-color); color:white; border:none; padding:10px; border-radius:8px; cursor:pointer;">등록</button>
            </div>
            <div id="admin-item-list"></div>
            <button onclick="closeAdmin()" style="width:100%; padding:10px; margin-top:20px; background:#333; color:white; border:none; border-radius:8px;">닫기</button>
        </div>
    </div>

    <div id="modal" class="modal">
        <div class="modal-content" style="width: 350px; font-family: monospace;">
            <div style="text-align:center; font-size:1.5rem; font-weight:bold; border-bottom:2px solid #000; padding-bottom:10px; margin-bottom:15px;">영 수 증</div>
            <div id="receipt-content"></div>
            <div style="display:flex; justify-content:space-between; margin-top:15px; border-top:1px dashed #000; padding-top:10px; font-weight:bold;">
                <span>거스름돈:</span><span id="receipt-change">0원</span>
            </div>
            <button onclick="closeReceipt()" style="width:100%; padding:10px; margin-top:20px; background:#333; color:white; border:none; border-radius:8px;">닫기</button>
        </div>
    </div>

    <script>
        // --- 사운드 & 음성 엔진 개선 ---
        let audioCtx = null;
        let isFirstInteraction = true;
        const bgMusic = document.getElementById('bg-music');
        let isMusicPlaying = false;

        function initApp() {
            if (isFirstInteraction) {
                // 오디오 컨텍스트 초기화
                if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
                
                // 배경음악 초기 설정 및 재생
                bgMusic.volume = 0.15; // 아주 작게 설정 (0.0~1.0)
                playMusic();
                
                isFirstInteraction = false;
            }
        }

        function playMusic() {
            bgMusic.play().then(() => {
                isMusicPlaying = true;
                document.getElementById('music-btn').innerText = "🎵 배경음 OFF";
                document.getElementById('music-btn').style.backgroundColor = "#fa5252";
            }).catch(e => console.log("자동 재생 차단됨:", e));
        }

        function toggleMusic() {
            if (isMusicPlaying) {
                bgMusic.pause();
                isMusicPlaying = false;
                document.getElementById('music-btn').innerText = "🎵 배경음 ON";
                document.getElementById('music-btn').style.backgroundColor = "#5c7cfa";
            } else {
                bgMusic.play();
                isMusicPlaying = true;
                document.getElementById('music-btn').innerText = "🎵 배경음 OFF";
                document.getElementById('music-btn').style.backgroundColor = "#fa5252";
            }
        }

        function playSound(type) {
            if (!audioCtx) return;
            const now = audioCtx.currentTime;
            if (type === 'click') {
                const osc = audioCtx.createOscillator(); const gain = audioCtx.createGain();
                osc.connect(gain); gain.connect(audioCtx.destination);
                osc.frequency.setValueAtTime(1200, now); osc.frequency.exponentialRampToValueAtTime(400, now + 0.05);
                gain.gain.setValueAtTime(0.1, now); gain.gain.exponentialRampToValueAtTime(0.01, now + 0.05);
                osc.start(); osc.stop(now + 0.05);
            } else if (type === 'clink') {
                [800, 1600, 2400].forEach((f, i) => {
                    const osc = audioCtx.createOscillator(); const gain = audioCtx.createGain();
                    osc.connect(gain); gain.connect(audioCtx.destination);
                    osc.frequency.setValueAtTime(f + Math.random()*100, now + i*0.02);
                    gain.gain.setValueAtTime(0.1, now + i*0.02); gain.gain.exponentialRampToValueAtTime(0.01, now + i*0.02 + 0.1);
                    osc.start(now + i*0.02); osc.stop(now + i*0.02 + 0.1);
                });
            } else if (type === 'success') {
                [523, 659, 783, 1046].forEach((f, i) => {
                    const o = audioCtx.createOscillator(); const g = audioCtx.createGain();
                    o.connect(g); g.connect(audioCtx.destination);
                    o.frequency.setValueAtTime(f, now + i*0.1); g.gain.setValueAtTime(0.1, now + i*0.1);
                    g.gain.exponentialRampToValueAtTime(0.01, now + i*0.1 + 0.4);
                    o.start(now + i*0.1); o.stop(now + i*0.1 + 0.4);
                });
            }
        }

        let currentLevel = 1; let cart = []; let totalAmount = 0; let paidAmount = 0;
        const defaultItems = {
            1: [{ id: 1, name: '우유', price: 1000, emoji: '🥛' }, { id: 2, name: '빵', price: 5000, emoji: '🍞' }],
            2: [{ id: 5, name: '사탕', price: 700, emoji: '🍭' }, { id: 6, name: '주스', price: 1200, emoji: '🧃' }]
        };
        let customItems = JSON.parse(localStorage.getItem('neulpum_mart_items')) || defaultItems;

        function init() { renderStore(); renderWallet(); updateUI(); }

        function renderStore() {
            const grid = document.getElementById('store-grid'); grid.innerHTML = '';
            customItems[currentLevel].forEach(item => {
                const card = document.createElement('div'); card.className = 'item-card';
                card.onclick = () => { playSound('click'); addToCart(item); };
                let visual = item.img ? `<img src="${item.img}" class="item-img">` : `<span class="item-emoji">${item.emoji || '📦'}</span>`;
                card.innerHTML = `${visual}<div style="font-weight:bold">${item.name}</div><div class="item-price">${item.price.toLocaleString()}원</div>`;
                grid.appendChild(card);
            });
        }

        function renderWallet() {
            const source = document.getElementById('money-source'); source.innerHTML = '';
            const notes = [
                { val: 1000, label: '1,000원', class: 'money-1000' },
                { val: 5000, label: '5,000원', class: 'money-5000' },
                { val: 10000, label: '10,000원', class: 'money-10000' },
                { val: 50000, label: '50,000원', class: 'money-50000' }
            ];
            const coins = [
                { val: 500, label: '500원', class: 'money-500' },
                { val: 100, label: '100원', class: 'money-100' }
            ];
            const displayList = currentLevel === 1 ? [notes[0]] : [...notes, ...coins];
            displayList.forEach(curr => {
                const div = document.createElement('div'); div.className = `money-item ${curr.class}`;
                div.draggable = true; div.title = curr.label;
                div.ondragstart = (e) => { playSound('click'); e.dataTransfer.setData('text', curr.val); e.dataTransfer.setData('class', curr.class); };
                source.appendChild(div);
            });
        }

        const dropZone = document.getElementById('drop-zone');
        dropZone.ondragover = e => e.preventDefault();
        dropZone.ondrop = e => {
            playSound('clink');
            const val = parseInt(e.dataTransfer.getData('text')); const cls = e.dataTransfer.getData('class');
            paidAmount += val;
            const m = document.createElement('div'); m.className = `money-item ${cls}`;
            m.style.position = 'absolute'; m.style.width = '120px';
            m.style.left = (Math.random() * (dropZone.offsetWidth - 120)) + 'px';
            m.style.top = (Math.random() * (dropZone.offsetHeight - 80)) + 'px';
            m.style.transform = `scale(0.6) rotate(${Math.random()*40-20}deg)`;
            dropZone.appendChild(m); updateUI();
        };

        function addToCart(item) { cart.push({...item, cartId: Date.now() + Math.random()}); totalAmount += item.price; updateUI(); }
        function removeFromCart(cartId) {
            playSound('click'); const idx = cart.findIndex(i => i.cartId === cartId);
            if (idx > -1) { totalAmount -= cart[idx].price; cart.splice(idx, 1); updateUI(); }
        }
        function emptyCart() { if (cart.length === 0) return; playSound('click'); cart = []; totalAmount = 0; updateUI(); }

        function updateUI() {
            const cartDiv = document.getElementById('cart-list');
            cartDiv.innerHTML = cart.length === 0 ? '<div style="text-align:center; color:#888; margin-top:40px;">물건을 담아주세요</div>' : 
                cart.map(i => `<div class="cart-item"><div><b>${i.name}</b><br><small>${i.price.toLocaleString()}원</small></div><button class="remove-btn" onclick="removeFromCart(${i.cartId})">X</button></div>`).join('');
            document.getElementById('total-amount').innerText = totalAmount.toLocaleString();
            document.getElementById('paid-amount').innerText = paidAmount.toLocaleString();
            document.getElementById('pay-btn').classList.toggle('enabled', totalAmount > 0 && paidAmount >= totalAmount);
        }

        function resetMoney() { playSound('click'); paidAmount = 0; dropZone.innerHTML = ''; updateUI(); }
        function setLevel(l) { playSound('click'); currentLevel = l; document.querySelectorAll('.level-btn').forEach((b, i) => b.classList.toggle('active', i+1 === l)); cart = []; totalAmount = 0; resetMoney(); renderStore(); renderWallet(); updateUI(); }
        function openHelp() { playSound('click'); document.getElementById('help-modal').style.display = 'flex'; }
        function closeHelp() { playSound('click'); document.getElementById('help-modal').style.display = 'none'; }
        function openAdmin() { playSound('click'); renderAdminList(); document.getElementById('admin-modal').style.display = 'flex'; }
        function closeAdmin() { playSound('click'); document.getElementById('admin-modal').style.display = 'none'; renderStore(); }

        function renderAdminList() {
            const list = document.getElementById('admin-item-list'); list.innerHTML = '';
            [1, 2].forEach(lvl => customItems[lvl].forEach(item => {
                const row = document.createElement('div'); row.className = 'admin-item-row';
                row.innerHTML = `<span>[Lv.${lvl}] ${item.name} (${item.price}원)</span><button class="delete-btn" onclick="deleteItem(${lvl}, ${item.id})">삭제</button>`;
                list.appendChild(row);
            }));
        }

        async function addNewItem() {
            const name = document.getElementById('new-item-name').value; const price = parseInt(document.getElementById('new-item-price').value); const lvl = document.getElementById('new-item-level').value; const file = document.getElementById('new-item-image').files[0];
            if (!name || !price) return alert("입력 확인");
            let imgData = file ? await toBase64(file) : null;
            customItems[lvl].push({ id: Date.now(), name, price, img: imgData });
            localStorage.setItem('neulpum_mart_items', JSON.stringify(customItems));
            playSound('success'); renderAdminList();
        }
        function deleteItem(lvl, id) { customItems[lvl] = customItems[lvl].filter(i => i.id !== id); localStorage.setItem('neulpum_mart_items', JSON.stringify(customItems)); renderAdminList(); }
        const toBase64 = file => new Promise((r, j) => { const rd = new FileReader(); rd.readAsDataURL(file); rd.onload = () => r(rd.result); });

        function completePayment() {
            if (paidAmount < totalAmount) return; playSound('success');
            const change = paidAmount - totalAmount;
            document.getElementById('receipt-content').innerHTML = cart.map(i => `<div style="display:flex; justify-content:space-between"><span>${i.name}</span><span>${i.price.toLocaleString()}</span></div>`).join('') + `<hr><div>합계: ${totalAmount.toLocaleString()}원</div><div>낸돈: ${paidAmount.toLocaleString()}원</div>`;
            document.getElementById('receipt-change').innerText = change.toLocaleString() + "원";
            document.getElementById('modal').style.display = 'flex';
        }
        function closeReceipt() { document.getElementById('modal').style.display = 'none'; emptyCart(); resetMoney(); }

        init();
    </script>
</body>
</html>
